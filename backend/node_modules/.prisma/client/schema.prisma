generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
  LEADER
  OPERATOR
}

model User {
  id            String   @id @default(uuid())
  name          String
  surname       String?
  cpf           String?  @unique
  email         String   @unique
  password_hash String
  role          Role     @default(OPERATOR)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  supervisor_id String?
  supervisor    User?   @relation("SupervisorToOperator", fields: [supervisor_id], references: [id])
  operators     User[]  @relation("SupervisorToOperator")

  // Team Relations
  team_id String?
  team    Team?   @relation("TeamMembers", fields: [team_id], references: [id])

  supervised_teams Team[] @relation("TeamSupervisor")
  led_teams        Team[] @relation("TeamLeader")

  clients        Client[]
  qualifications Qualification[]

  @@map("users")
}

model Client {
  id                 String   @id @default(uuid())
  name               String
  surname            String?
  cnpj               String   @unique
  email              String
  phone              String
  is_qualified       Boolean  @default(false)
  has_open_account   Boolean  @default(false)
  answers            Json?    @default("{}")
  integration_status String   @default("Cadastrando...")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  id_bitrix          Int?

  created_by_id String
  created_by    User   @relation(fields: [created_by_id], references: [id])

  qualifications Qualification[]

  @@map("clients")
}

model Qualification {
  id      String @id @default(uuid())
  answers Json

  // New Qualification fields
  emite_boletos          Boolean?  @default(false)
  maquininha_atual       String?
  faturamento_maquina    Decimal?  @db.Decimal(15, 2)
  faturamento_mensal     Decimal?  @db.Decimal(15, 2)
  produto_interesse      String?
  deseja_receber_ofertas Boolean?  @default(false)
  informacoes_adicionais String?
  nome_do_cliente        String?
  fase                   String?
  tabulacao              String?
  agendamento            DateTime?
  created_at             DateTime  @default(now())

  // Integration Control
  integration_status       String?   @default("PENDING")
  integration_attempts     Int?      @default(0)
  last_integration_attempt DateTime?
  webhook_response         String?

  client_id String
  client    Client @relation(fields: [client_id], references: [id])

  created_by_id String
  created_by    User   @relation(fields: [created_by_id], references: [id])

  @@map("qualifications")
}

model FormTemplate {
  id         String   @id @default(uuid())
  title      String
  fields     Json // Array of field definitions (label, type, options)
  type       String   @default("QUALIFICATION") // QUALIFICATION or REGISTRATION
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  @@map("form_templates")
}

model Team {
  id         String   @id @default(uuid())
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  supervisor_id String
  supervisor    User   @relation("TeamSupervisor", fields: [supervisor_id], references: [id])

  leader_id String?
  leader    User?   @relation("TeamLeader", fields: [leader_id], references: [id])

  members User[] @relation("TeamMembers")

  @@map("teams")
}
