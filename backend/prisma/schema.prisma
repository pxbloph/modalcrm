
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
  LEADER
  OPERATOR
}



model User {
  id            String   @id @default(uuid())
  name          String
  surname       String?
  cpf           String?  @unique
  email         String   @unique
  password_hash String
  role          Role     @default(OPERATOR)
  is_active     Boolean  @default(true)
  initial_page  String   @default("DEFAULT")
  created_at    DateTime @default(now())

  supervisor_id String?
  supervisor    User?   @relation("SupervisorToOperator", fields: [supervisor_id], references: [id])
  operators     User[]  @relation("SupervisorToOperator")



  clients        Client[]
  import_jobs    ImportJob[]

  // Kanban Relations
  responsible_deals Deal[]
  deal_actions      DealHistory[]

  // Chat Relations
  conversations_as_operator   Conversation[] @relation("OperatorConversations")
  conversations_as_supervisor Conversation[] @relation("SupervisorConversations")
  sent_messages               Message[]      @relation("SentMessages")
  audit_logs                  ChatAuditLog[]
  pipeline_configs            UserPipelineConfig[]

  // Lead Transfer Relations
  clients_contacted           Client[]       @relation("ClientLastContact")
  requested_transfers         LeadOwnerTransferAudit[] @relation("TransferRequester")
  legacy_owner_transfers      LeadOwnerTransferAudit[] @relation("TransferOldOwner")
  new_owner_transfers         LeadOwnerTransferAudit[] @relation("TransferNewOwner")
  deleted_lead_archives       DeletedLeadArchive[]

  // Announcement Relations
  authored_announcements Announcement[]
  read_announcements     AnnouncementRead[]

  // Audit Relations
  audit_actions          AuditLog[]
  kanban_filter_presets  KanbanFilterPreset[]
  kanban_preferences     UserKanbanPreference[]
  api_keys               ApiKey[] @relation("UserApiKeys")

  team                   String?

  security_role_id       String?
  security_role          SecurityRole? @relation("SecurityRoleAssignments", fields: [security_role_id], references: [id])
  permissions_override   Json? @default("[]")
  created_security_roles SecurityRole[] @relation("SecurityRoleCreator")
  created_dev_notes      DevNote[] @relation("DevNoteCreator")
  dev_note_daily_views   DevNoteDailyView[]
  dev_note_reads         DevNoteRead[]

  @@index([supervisor_id])
  @@index([is_active, role])
  @@map("users")
}

model KanbanFilterPreset {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  name        String
  is_default  Boolean  @default(false)
  config_json Json     // { visible_fields: string[], values: any, order: string[] }
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("kanban_filter_presets")
}

model UserKanbanPreference {
  id              String   @id @default(uuid())
  user_id         String
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  pipeline_id     String
  pipeline        Pipeline @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  
  view_mode       String   @default("board") // board, list
  page_size       Int      @default(25)
  visible_fields  Json     @default("[]")    // Fields in the filter bar
  visible_columns Json     @default("[]")    // Columns in the list view
  filters_config  Json     @default("{}")    // Applied filter values
  
  updated_at      DateTime @updatedAt

  @@unique([user_id, pipeline_id])
  @@map("user_kanban_preferences")
}

model Client {
  id        String       @id @default(uuid())
  name      String
  surname   String?
  cnpj      String       @unique
  email     String
  phone     String
  is_qualified     Boolean @default(false)
  has_open_account Boolean @default(false)
  answers   Json?    @default("{}")
  integration_status String @default("Cadastrando...")
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  id_bitrix  Int?
  
  // Extended Company Details
  address           String?
  cnae_main         String?
  cnae_secondary    String?
  legal_nature      String?
  registration_status String? // ATIVA, BAIXADA, etc
  registration_status_date DateTime?
  opening_date      DateTime?
  account_opening_date DateTime? // Data de abertura da conta (Preenchido na tabulação "Conta aberta")
  share_capital     Decimal? @db.Decimal(15, 2)
  
  // Bitrix Legacy Fields (Preserved for Reference)
  id_card_bitrix    String?
  id_contact_bitrix String?


  created_by_id String
  created_by    User   @relation(fields: [created_by_id], references: [id])

  deals          Deal[]
  custom_field_values ClientCustomFieldValue[]

  // Responsibility Transfer
  last_contact_user_id String?
  last_contact_user    User?    @relation("ClientLastContact", fields: [last_contact_user_id], references: [id])
  last_contact_at      DateTime?
  
  // --- Merged Qualification Fields (Simplification) ---
  
  // Financial & Business
  faturamento_mensal    Decimal? @db.Decimal(15, 2)
  faturamento_maquina   Decimal? @db.Decimal(15, 2)
  maquininha_atual      String?
  produto_interesse     String?
  emite_boletos         Boolean? @default(false)
  deseja_receber_ofertas Boolean? @default(false)
  informacoes_adicionais String?
  tabulacao             String?
  agendamento           DateTime?

  // A) Conta Corrente (New Panel)
  cc_tipo_conta         String?
  cc_status             String?
  cc_numero             String?
  cc_saldo              Decimal? @db.Decimal(15, 2)
  cc_limite_utilizado   Decimal? @db.Decimal(15, 2)
  cc_limite_disponivel  Decimal? @db.Decimal(15, 2)

  // B) Cartão de Crédito
  card_final            String?
  card_status           String?
  card_tipo             String?
  card_adicionais       Int?
  card_fatura_aberta_data DateTime?
  card_fatura_aberta_valor Decimal? @db.Decimal(15, 2)

  // C) Conta Global
  global_dolar          Boolean? @default(false)
  global_euro           Boolean? @default(false)

  // D) Outros Produtos
  prod_multiplos_acessos Boolean? @default(false)
  prod_c6_pay           Boolean? @default(false)
  prod_c6_tag           Boolean? @default(false)
  prod_debito_automatico Boolean? @default(false)
  prod_seguros          Boolean? @default(false)
  prod_chaves_pix       Boolean? @default(false)
  prod_web_banking      Boolean? @default(false)
  prod_link_pagamento   Boolean? @default(false)
  prod_boleto_dda       Boolean? @default(false)
  prod_boleto_cobranca  Boolean? @default(false)

  // E) Limites de Crédito
  credit_blocklist      Boolean? @default(false)
  credit_score_interno  String?  @default("Informação indisponível")
  credit_score_serasa   String?  @default("Informação indisponível")
  credit_inadimplencia  String?  @default("Em dia")

  limit_cartao_utilizado Decimal? @db.Decimal(15, 2)
  limit_cartao_aprovado  Decimal? @db.Decimal(15, 2)
  limit_cheque_utilizado Decimal? @db.Decimal(15, 2)
  limit_cheque_aprovado  Decimal? @db.Decimal(15, 2)
  limit_parcelado_utilizado Decimal? @db.Decimal(15, 2)
  limit_parcelado_aprovado  Decimal? @db.Decimal(15, 2)
  limit_anticipacao_disponivel String? @default("Informação indisponível")
  
  transfer_audits      LeadOwnerTransferAudit[]

  @@index([created_by_id])
  @@index([created_at])
  @@index([integration_status])
  @@index([tabulacao])
  @@index([account_opening_date])
  @@index([has_open_account])
  @@map("clients")
}

model DeletedLeadArchive {
  id                     String   @id @default(uuid())
  original_lead_id       String
  name                   String
  surname                String?
  cnpj                   String
  email                  String
  phone                  String
  integration_status     String?
  tabulacao              String?
  original_owner_id      String?
  original_owner_name    String?
  attempted_by_user_id   String
  attempted_by_user      User     @relation(fields: [attempted_by_user_id], references: [id])
  archive_reason         String
  archive_context        String?
  original_payload       Json?
  deleted_at             DateTime @default(now())
  restored_at            DateTime?
  restored_by_user_id    String?
  restored_client_id     String?

  @@index([deleted_at])
  @@index([cnpj])
  @@index([attempted_by_user_id])
  @@map("deleted_leads_archive")
}

model SystemSetting {
  key         String   @id
  value_json  Json
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("system_settings")
}

model DevNote {
  id                  String        @id @default(uuid())
  title               String
  content             String
  is_active           Boolean       @default(true)
  show_in_daily_popup Boolean       @default(true)
  created_by_id       String?
  created_by          User?         @relation("DevNoteCreator", fields: [created_by_id], references: [id])
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  reads               DevNoteRead[]

  @@index([is_active, created_at])
  @@map("dev_notes")
}

model DevNoteRead {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  note_id    String
  note       DevNote  @relation(fields: [note_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@unique([user_id, note_id])
  @@map("dev_note_reads")
}

model DevNoteDailyView {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  day_key    String
  created_at DateTime @default(now())

  @@unique([user_id, day_key])
  @@index([day_key])
  @@map("dev_note_daily_views")
}


model FormTemplate {
  id        String   @id @default(uuid())
  title     String
  fields    Json     // Array of field definitions (label, type, options)
  type      String   @default("QUALIFICATION") // QUALIFICATION or REGISTRATION
  is_active Boolean  @default(true)
  created_at DateTime @default(now())

  @@map("form_templates")
}



model ImportJob {
  id                String   @id @default(uuid()) @db.Uuid
  type              String   // 'OPEN_ACCOUNTS'
  status            String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  file_name         String
  total_records     Int      @default(0)
  processed_records Int      @default(0)
  success_count     Int      @default(0)
  error_count       Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  created_by_id     String
  created_by        User     @relation(fields: [created_by_id], references: [id])

  results           ImportResult[]

  @@map("import_jobs")
}

model ImportResult {
  id          String    @id @default(uuid()) @db.Uuid
  job_id      String    @db.Uuid
  job         ImportJob @relation(fields: [job_id], references: [id], onDelete: Cascade)
  
  row_data    Json?
  status      String    // UPDATED, NOT_FOUND, INVALID, DUPLICATE, ERROR
  message     String?
  created_at  DateTime  @default(now())

  @@map("import_results")
}

model Conversation {
  id              String   @id @default(uuid())
  operator_id     String
  operator        User     @relation("OperatorConversations", fields: [operator_id], references: [id])
  supervisor_id   String
  supervisor      User     @relation("SupervisorConversations", fields: [supervisor_id], references: [id])
  last_message_at DateTime @default(now())
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  messages        Message[]

  @@unique([operator_id, supervisor_id])
  @@index([operator_id])
  @@index([supervisor_id])
  @@index([last_message_at])
  @@map("conversations")
}

model Message {
  id                String   @id @default(uuid())
  conversation_id   String
  conversation      Conversation @relation(fields: [conversation_id], references: [id])
  sender_id         String
  sender            User     @relation("SentMessages", fields: [sender_id], references: [id])
  body              String
  is_read           Boolean  @default(false)
  client_message_id String?
  created_at        DateTime @default(now())
  read_at           DateTime?

  @@index([conversation_id, created_at])
  @@map("messages")
}

model ChatAuditLog {
  id         String   @id @default(uuid())
  admin_id   String
  admin      User     @relation(fields: [admin_id], references: [id])
  action     String
  target_id  String?
  details    String?
  created_at DateTime @default(now())

  @@map("chat_audit_logs")
}

model LeadOwnerTransferAudit {
  id                   String   @id @default(uuid())
  lead_id              String
  lead                 Client   @relation(fields: [lead_id], references: [id])
  
  old_owner_id         String
  old_owner            User     @relation("TransferOldOwner", fields: [old_owner_id], references: [id])
  
  new_owner_id         String
  new_owner            User     @relation("TransferNewOwner", fields: [new_owner_id], references: [id])
  
  requested_by_user_id String
  requested_by_user    User     @relation("TransferRequester", fields: [requested_by_user_id], references: [id])
  
  mode                 String   // 'operator_single' | 'supervisor_single' | 'supervisor_bulk' | 'system_auto'
  reason               String?
  
  created_at           DateTime @default(now())

  @@map("lead_owner_transfer_audit")
}

// KANBAN SYSTEM MODELS

enum PipelineVisibility {
  PUBLIC
  PRIVATE
  RESTRICTED
}

model Pipeline {
  id          String   @id @default(uuid())
  name        String
  description String?
  is_active   Boolean  @default(true)
  is_default  Boolean  @default(false)
  visibility  PipelineVisibility @default(PUBLIC)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  stages       PipelineStage[]
  deals        Deal[]
  custom_fields CustomField[]
  automations  Automation[]
  tabulation_triggers DealTabulationTrigger[]
  user_configs UserPipelineConfig[]
  kanban_preferences   UserKanbanPreference[]

  @@map("pipelines")
}

model PipelineStage {
  id          String   @id @default(uuid())
  pipeline_id String
  pipeline    Pipeline @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  
  name        String
  color       String   @default("#000000")
  order_index Int
  is_active   Boolean  @default(true)
  
  // Settings
  sla_minutes Int?     @default(0)

  
  deals       Deal[]
  automations Automation[]
  field_configs CustomFieldStageConfig[]

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tabulations Tabulation[]

  @@index([pipeline_id, order_index])
  @@map("pipeline_stages")
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
  USER
}

model CustomField {
  id          String    @id @default(uuid())
  pipeline_id String
  pipeline    Pipeline  @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  
  key         String
  label       String
  type        FieldType
  options     Json?     // ["Option A", "Option B"]
  
  is_required Boolean   @default(false)
  is_visible  Boolean   @default(true)
  config      Json?     @default("{}")

  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  values      DealCustomFieldValue[]
  stage_configs CustomFieldStageConfig[]

  @@unique([pipeline_id, key])
  @@map("custom_fields")
}

model CustomFieldStageConfig {
  id              String      @id @default(uuid())
  field_id        String
  field           CustomField @relation(fields: [field_id], references: [id], onDelete: Cascade)
  
  stage_id        String
  stage           PipelineStage @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  
  is_required     Boolean     @default(false)
  is_visible      Boolean     @default(true)
  
  @@unique([field_id, stage_id])
  @@map("custom_field_stage_configs")
}

enum DealStatus {
  OPEN
  WON
  LOST
  ABANDONED
}

enum DealPriority {
  LOW
  NORMAL
  HIGH
}

model Deal {
  id           String   @id @default(uuid())
  title        String
  
  pipeline_id  String
  pipeline     Pipeline @relation(fields: [pipeline_id], references: [id])
  
  stage_id     String
  stage        PipelineStage @relation(fields: [stage_id], references: [id])
  
  client_id    String?
  client       Client?   @relation(fields: [client_id], references: [id])
  
  responsible_id String?
  responsible    User?   @relation(fields: [responsible_id], references: [id])

  status       DealStatus   @default(OPEN)
  value        Decimal? @db.Decimal(15, 2)
  priority     DealPriority   @default(NORMAL)
  
  // SLA Control
  is_overdue   Boolean      @default(false)
  sla_start_date DateTime?
  sla_due_date   DateTime?

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  
  stage_entered_at DateTime @default(now())
  
  custom_values DealCustomFieldValue[]
  history       DealHistory[]
  tags          DealTag[]

  @@index([pipeline_id])
  @@index([stage_id])
  @@index([responsible_id])
  @@index([client_id])
  @@index([status])
  @@index([created_at])
  @@index([pipeline_id, stage_id])
  @@index([pipeline_id, status])
  @@index([responsible_id, status])
  @@map("deals")
}

model DealCustomFieldValue {
  id              String      @id @default(uuid())
  deal_id         String
  deal            Deal        @relation(fields: [deal_id], references: [id], onDelete: Cascade)
  
  field_id        String
  field           CustomField @relation(fields: [field_id], references: [id], onDelete: Restrict)
  
  value           String?
  value_json      Json?
  
  updated_at      DateTime    @updatedAt

  @@unique([deal_id, field_id])
  @@map("deal_custom_field_values")
}

model DealHistory {
  id          String   @id @default(uuid())
  deal_id     String
  deal        Deal     @relation(fields: [deal_id], references: [id], onDelete: Cascade)
  
  actor_id    String?
  actor       User?    @relation(fields: [actor_id], references: [id])
  
  action      String
  details     Json?
  
  created_at  DateTime @default(now())

  @@index([deal_id])
  @@index([deal_id, created_at])
  @@map("deal_history")
}

enum AutomationTrigger {
  ENTER_STAGE
  LEAVE_STAGE
  SLA_WARNING
  SLA_BREACH
  FIELD_UPDATE
  TABULATION_UPDATE
}

model Automation {
  id          String   @id @default(uuid())
  pipeline_id String
  pipeline    Pipeline @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  
  stage_id    String?
  stage       PipelineStage? @relation(fields: [stage_id], references: [id])

  name        String
  trigger     AutomationTrigger
  
  conditions  Json?    @default("[]")
  actions     Json
  
  is_active   Boolean  @default(true)
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tabulation_triggers DealTabulationTrigger[]

  @@map("automations")
}

model DealTabulationTrigger {
  id            String   @id @default(uuid())
  tabulation    String   // "Conta aberta", etc
  
  pipeline_id   String
  pipeline      Pipeline @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  
  automation_id String
  automation    Automation @relation(fields: [automation_id], references: [id], onDelete: Cascade)

  created_at    DateTime @default(now())

  @@map("deal_tabulation_triggers")
}





model UserPipelineConfig {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  pipeline_id String
  pipeline    Pipeline @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)

  card_config Json     @default("{}") // Stores field visibility and order
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([user_id, pipeline_id])
  @@map("user_pipeline_configs")
}

// --- CLIENT CUSTOM FIELDS SYSTEM (EAV) ---

model CustomFieldGroup {
  id          String   @id @default(uuid())
  name        String
  order_index Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  fields      ClientCustomField[]

  @@map("custom_field_groups")
}

model ClientCustomField {
  id          String   @id @default(uuid())
  group_id    String
  group       CustomFieldGroup @relation(fields: [group_id], references: [id])

  key         String   @unique // API Key unique
  label       String
  type        String   // 'TEXT', 'NUMBER', 'DATE', 'BOOLEAN', 'SELECT', 'MULTI_SELECT', 'CURRENCY', 'TEXTAREA'
  options_json Json?   // For select/multiselect
  
  is_required Boolean  @default(false)
  order_index Int      @default(0)
  is_active   Boolean  @default(true)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  values      ClientCustomFieldValue[]

  @@map("custom_fields_client")
}

model ClientCustomFieldValue {
  id          String   @id @default(uuid())
  
  client_id   String
  client      Client   @relation(fields: [client_id], references: [id])

  field_id    String
  field       ClientCustomField @relation(fields: [field_id], references: [id])

  value_text   String?
  value_number Decimal? @db.Decimal(65, 30)
  value_date   DateTime?
  value_bool   Boolean?
  value_json   Json?

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([client_id, field_id])
  @@index([client_id])
  @@index([field_id])
  @@map("client_custom_field_values")
}

// --- ANNOUNCEMENTS SYSTEM ---

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  priority  String   @default("NORMAL") // NORMAL, HIGH, URGENT
  
  author_id String
  author    User     @relation(fields: [author_id], references: [id])
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  reads     AnnouncementRead[]

  @@index([author_id])
  @@map("announcements")
}

model AnnouncementRead {
  id              String       @id @default(uuid())
  
  announcement_id String
  announcement    Announcement @relation(fields: [announcement_id], references: [id], onDelete: Cascade)
  
  user_id         String
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  read_at         DateTime     @default(now())

  @@unique([announcement_id, user_id])
  @@map("announcement_reads")
}

// --- TABULATION SYSTEM ---

model Tabulation {
  id              String   @id @default(uuid())
  label           String
  is_active       Boolean  @default(true)
  
  target_stage_id String?
  target_stage    PipelineStage? @relation(fields: [target_stage_id], references: [id])

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("tabulations")
}

// --- TAG SYSTEM ---

model Tag {
  id          String   @id @default(uuid())
  name        String
  color       String   @default("#64748b")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  deals       DealTag[]

  @@map("tags")
}

model DealTag {
  deal_id     String
  deal        Deal     @relation(fields: [deal_id], references: [id], onDelete: Cascade)

  tag_id      String
  tag         Tag      @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  assigned_at DateTime @default(now())

  @@id([deal_id, tag_id])
  @@map("deal_tags")
}

// --- AUDIT SYSTEM ---

model AuditLog {
  id                  String   @id @default(uuid())
  created_at          DateTime @default(now())
  environment         String   @default("prod") // prod, stage, dev
  level               String   // DEBUG, INFO, WARN, ERROR
  event_type          String   // USER_LOGIN, DEAL_UPDATED, etc
  entity_type         String   // Client, Deal, Use, etc
  entity_id           String?
  action              String   // CREATE, UPDATE, DELETE, etc
  
  actor_id            String?
  actor               User?    @relation(fields: [actor_id], references: [id])
  
  impersonated_by_id  String?
  request_id          String?
  trace_id            String?
  ip_address          String?
  user_agent          String?
  route               String?
  method              String?
  status_code         Int?
  duration_ms         Int?
  success             Boolean  @default(true)
  error_message       String?
  tags                Json?

  payload             AuditLogPayload?

  @@index([created_at])
  @@index([event_type])
  @@index([entity_type, entity_id])
  @@index([actor_id])
  @@index([request_id])
  @@map("audit_logs")
}

model AuditLogPayload {
  id            String   @id @default(uuid())
  audit_log_id  String   @unique
  audit_log     AuditLog @relation(fields: [audit_log_id], references: [id], onDelete: Cascade)
  
  before        Json?
  after         Json?
  metadata      Json?
  request_body  Json?
  response_body Json?

  @@map("audit_log_payloads")
}


// --- SECURITY ROLES SYSTEM ---

model SecurityRole {
  id               String   @id @default(uuid())
  name             String   @unique
  description      String?
  base_role        Role?
  initial_page     String   @default("DEFAULT")
  is_system        Boolean  @default(false)
  permissions_json Json     @default("[]")

  created_by_id    String?
  created_by       User?    @relation("SecurityRoleCreator", fields: [created_by_id], references: [id])

  users            User[]   @relation("SecurityRoleAssignments")

  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("security_roles")
}
// --- API KEYS SYSTEM ---

model ApiKey {
  id            String   @id @default(uuid())
  name          String   // Nome de identificação da chave (ex: Webhook n8n)
  key           String   @unique
  is_active     Boolean  @default(true)
  last_used_at  DateTime?

  created_by_id String
  created_by    User     @relation("UserApiKeys", fields: [created_by_id], references: [id])

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([key])
  @@map("api_keys")
}



